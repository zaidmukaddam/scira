# =============================================================================
# SCIRA — متغيرات البيئة للنشر والإنتاج
# نسخ هذا الملف إلى .env.production أو أضف القيم في لوحة Vercel / Cloud
# =============================================================================

# ─── مزودو نماذج الذكاء الاصطناعي (مطلوب) ───────────────────────────────────
XAI_API_KEY=                        # xAI — https://console.x.ai
OPENAI_API_KEY=                     # OpenAI — https://platform.openai.com/api-keys
GROQ_API_KEY=                       # Groq — https://console.groq.com/keys
GOOGLE_GENERATIVE_AI_API_KEY=       # Google AI Studio — https://aistudio.google.com/app/apikey
# ANTHROPIC_API_KEY=                # اختياري — https://console.anthropic.com

# ─── مزودو نماذج إضافيون (اختياري) ──────────────────────────────────────────
ARK_API_KEY=                        # ByteDance Ark — https://ark.ap-southeast.bytepluses.com
ZAI_API_KEY=                        # Z.ai GLM — https://z.ai
SARVAM_API_KEY=                     # Sarvam AI — https://dashboard.sarvam.ai
HF_TOKEN=                           # HuggingFace — https://huggingface.co/settings/tokens
NOVITA_API_KEY=                     # Novita AI — https://novita.ai
OPENROUTER_API_KEY=                 # OpenRouter — https://openrouter.ai/keys
MINIMAX_API_KEY=                    # MiniMax — https://api.minimax.io
OPENAI_API_KEY_2=                   # OpenAI ثانوي — نسخة احتياطية لـ OPENAI_API_KEY

# ─── قاعدة البيانات (مطلوب) ─────────────────────────────────────────────────
DATABASE_URL=                       # PostgreSQL — مثال: postgres://user:pass@host:5432/dbname
READ_DB_1=                          # قاعدة بيانات للقراءة (replica 1) — نفس شكل DATABASE_URL
READ_DB_2=                          # قاعدة بيانات للقراءة (replica 2) — نفس شكل DATABASE_URL

# ─── Redis والتخزين المؤقت (مطلوب) ──────────────────────────────────────────
REDIS_URL=                          # Redis — مثال: redis://user:pass@host:6379
UPSTASH_REDIS_REST_URL=             # Upstash REST URL — https://console.upstash.com
UPSTASH_REDIS_REST_TOKEN=           # Upstash REST Token

# ─── التخزين السحابي (مطلوب) ─────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=              # Vercel Blob — https://vercel.com/dashboard/stores
R2_ACCOUNT_ID=                      # Cloudflare R2 Account ID
R2_ACCESS_KEY_ID=                   # Cloudflare R2 Access Key
R2_SECRET_ACCESS_KEY=               # Cloudflare R2 Secret Key
R2_BUCKET_NAME=                     # اسم الـ bucket في R2
R2_PUBLIC_URL=                      # رابط الـ bucket العام — مثال: https://pub-xxx.r2.dev

# ─── المصادقة — Better Auth (مطلوب) ─────────────────────────────────────────
BETTER_AUTH_SECRET=                 # سر عشوائي ≥32 حرف — توليد: openssl rand -base64 32
BETTER_AUTH_BASE_URL=               # رابط التطبيق — مثال: https://scira.ai
BETTER_AUTH_URL=                    # نفس BETTER_AUTH_BASE_URL

# ─── مزودو OAuth للمصادقة (مطلوب) ───────────────────────────────────────────
GITHUB_CLIENT_ID=                   # GitHub OAuth App — https://github.com/settings/developers
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=                   # Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=                  # Twitter/X OAuth — https://developer.twitter.com/en/portal
TWITTER_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=                # Azure App Registration — https://portal.azure.com
MICROSOFT_CLIENT_SECRET=

# ─── مدفوعات Polar (مطلوب للاشتراكات) ───────────────────────────────────────
POLAR_ACCESS_TOKEN=                 # Polar Dashboard — https://polar.sh/dashboard
POLAR_WEBHOOK_SECRET=               # من قسم Webhooks في Polar

# ─── مدفوعات Dodo Payments (اختياري) ────────────────────────────────────────
DODO_PAYMENTS_API_KEY=              # https://dashboard.dodopayments.com
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_STUD_DISC_ID=                  # معرف خصم طلاب Dodo (اختياري)
DODO_MAX_PRODUCT_ID=                # معرف منتج Max في Dodo (اختياري)

# ─── البحث على الويب (مطلوب) ─────────────────────────────────────────────────
TAVILY_API_KEY=                     # Tavily Search — https://app.tavily.com
EXA_API_KEY=                        # Exa AI — https://dashboard.exa.ai
FIRECRAWL_API_KEY=                  # Firecrawl — https://www.firecrawl.dev
PARALLEL_API_KEY=                   # Parallel Web — https://parallel.ai
VALYU_API_KEY=                      # Valyu Network — https://dashboard.valyu.network
NOTTE_API_KEY=                      # Notte (اختياري) — https://notte.cc
SUPADATA_API_KEY=                   # Supadata — https://supadata.ai

# ─── الخرائط والطقس والسفر (مطلوب) ──────────────────────────────────────────
GOOGLE_MAPS_API_KEY=                # Google Maps Platform Server Key — https://console.cloud.google.com
OPENWEATHER_API_KEY=                # OpenWeatherMap — https://home.openweathermap.org/api_keys
AMADEUS_API_KEY=                    # Amadeus for Dev — https://developers.amadeus.com
AMADEUS_API_SECRET=

# ─── وسائط وترفيه (مطلوب) ────────────────────────────────────────────────────
TMDB_API_KEY=                       # TMDB — https://www.themoviedb.org/settings/api
YT_ENDPOINT=                        # YouTube endpoint مخصص (مثال: https://youryt.example.com)
ELEVENLABS_API_KEY=                 # ElevenLabs — https://elevenlabs.io/app/settings/api-keys
SPOTIFY_CLIENT_ID=                  # Spotify Developer — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_SECRET=
COINGECKO_API_KEY=                  # CoinGecko — https://www.coingecko.com/en/api

# ─── ذاكرة وMCP (مطلوب) ──────────────────────────────────────────────────────
SUPERMEMORY_API_KEY=                # Supermemory — https://supermemory.ai
SMITHERY_API_KEY=                   # Smithery MCP — https://smithery.ai
MCP_CREDENTIALS_ENCRYPTION_KEY=    # مفتاح تشفير ≥32 حرف عشوائي: openssl rand -hex 32
MCP_OAUTH_CALLBACK_ORIGIN=         # أصل OAuth للـ MCP — مثال: https://scira.ai

# ─── MCP OAuth Apps (اختياري — لكل تكامل) ────────────────────────────────────
GITHUB_MCP_CLIENT_ID=
GITHUB_MCP_CLIENT_SECRET=
SLACK_MCP_CLIENT_ID=
SLACK_MCP_CLIENT_SECRET=
BOX_MCP_CLIENT_ID=
BOX_MCP_CLIENT_SECRET=
DROPBOX_MCP_CLIENT_ID=
DROPBOX_MCP_CLIENT_SECRET=
HUBSPOT_MCP_CLIENT_ID=
HUBSPOT_MCP_CLIENT_SECRET=
UPSTASH_BOX_API_KEY=

# ─── البريد الإلكتروني والجدولة (مطلوب) ──────────────────────────────────────
RESEND_API_KEY=                     # Resend — https://resend.com/api-keys
QSTASH_TOKEN=                       # Upstash QStash — https://console.upstash.com/qstash
CRON_SECRET=                        # سر عشوائي لتأمين cron endpoints

# ─── Code Interpreter / Sandbox (مطلوب لأداة كتابة الكود) ────────────────────
DAYTONA_API_KEY=                    # Daytona — https://app.daytona.io/settings/api-keys
TTC_API_KEY=                        # Token Counter Client (extreme-search)

# ─── Cloudflare Workers AI (مطلوب لنماذج CF) ────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=              # قسم Overview في لوحة Cloudflare
CLOUDFLARE_API_TOKEN=               # https://dash.cloudflare.com/profile/api-tokens

# ─── إعدادات الأمان والبيئة ───────────────────────────────────────────────────
ALLOWED_ORIGINS=                    # للإنتاج: https://scira.ai — للتطوير: http://localhost:3000
NGROK_URL=                          # للتطوير المحلي فقط — للاختبار مع Cron/Lookout

# ─── متغيرات عامة (NEXT_PUBLIC) ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=                # رابط التطبيق العام — مثال: https://scira.ai
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=    # Google Maps Browser Key (مختلف عن Server Key)
NEXT_PUBLIC_MCP_ENABLED=true        # تفعيل MCP في الواجهة

# ─── خطط الاشتراك (مطلوب مع Polar) ──────────────────────────────────────────
NEXT_PUBLIC_STARTER_TIER=           # معرف منتج Starter في Polar
NEXT_PUBLIC_STARTER_SLUG=           # slug منتج Starter
NEXT_PUBLIC_PREMIUM_TIER=           # معرف منتج Premium
NEXT_PUBLIC_PREMIUM_SLUG=           # slug منتج Premium
NEXT_PUBLIC_MAX_TIER=               # معرف منتج Max
NEXT_PUBLIC_MAX_SLUG=               # slug منتج Max

# ─── خادم Build Mode (اختياري) ───────────────────────────────────────────────
NEXT_PUBLIC_BUILD_SERVER_URL=       # رابط خادم Build المدمج
NEXT_PUBLIC_BUILD_SERVER_SECRET=    # سر اتصال Build Server

# ─── تحليلات (اختياري) ───────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=            # PostHog — https://app.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=           # مثال: https://app.posthog.com
NEXT_PUBLIC_MAPBOX_TOKEN=           # Mapbox Public Token — https://account.mapbox.com
